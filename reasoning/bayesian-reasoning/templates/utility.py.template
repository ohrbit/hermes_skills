## Example: Goal Programming

```python
# models/utilities/goal_programming.py

def goal_utility(
    success: bool,
    collision_prob: float,
    time_cost: float,
    thresholds: dict = None
) -> float:
    """
    Goal programming: minimize weighted deviation from targets.
    """
    thresholds = thresholds or {
        "success": 1.0,           # target: succeed
        "collision_prob": 0.001,  # target: very safe
        "time_cost": 30.0,        # target: under 30s
    }
    
    weights = {
        "success": 100.0,
        "collision_prob": 10000.0,
        "time_cost": 1.0,
    }
    
    penalty = 0.0
    if not success:
        penalty += weights["success"] * 1.0
    if collision_prob > thresholds["collision_prob"]:
        penalty += weights["collision_prob"] * (collision_prob - thresholds["collision_prob"])
    if time_cost > thresholds["time_cost"]:
        penalty += weights["time_cost"] * (time_cost - thresholds["time_cost"])
    
    return -penalty  # minimize penalty = maximize utility
```

