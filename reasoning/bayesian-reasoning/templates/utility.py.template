## Example: CVaR Utility Wrapper

```python
# models/utilities/cvar_utility.py
import numpy as np
from typing import Callable, List

def cvar_utility(
    base_utility_fn: Callable,
    scenarios: List[dict],      # list of {variables: values}
    alpha: float = 0.05         # CVaR level (5% tail)
) -> float:
    """
    Compute Conditional Value at Risk (CVaR) of utility.
    
    CVaR_α = E[U | U ≤ VaR_α]
    Optimizes worst-case α-quantile outcomes.
    """
    utilities = []
    for s in scenarios:
        u = base_utility_fn(**s)
        utilities.append(u)
    
    utilities = np.array(utilities)
    var_alpha = np.percentile(utilities, alpha * 100)
    cvar = utilities[utilities <= var_alpha].mean()
    
    return cvar


def entropic_utility(
    base_utility_fn: Callable,
    scenarios: List[dict],
    theta: float = 1.0          # risk aversion parameter
) -> float:
    """
    Entropic risk measure: ρ_θ(U) = (1/θ) log E[exp(-θ U)]
    θ > 0: risk averse, θ → 0: risk neutral, θ < 0: risk seeking
    """
    utilities = np.array([base_utility_fn(**s) for s in scenarios])
    
    if abs(theta) < 1e-8:
        return utilities.mean()
    
    return (1.0 / theta) * np.log(np.mean(np.exp(-theta * utilities)))
```

