## Example: Sensor Model (Occupancy Grid)

```python
# models/factors/sensor_model.py
import numpy as np

# P(measurement | true_state)
# Measurement: 0=free, 1=occupied, 2=unknown
# True state: 0=free, 1=occupied
SENSOR_MODEL = np.array([
    # free   occupied
    [0.9,  0.1],   # measure free
    [0.2,  0.8],   # measure occupied
    [0.5,  0.5],   # unknown
])

def get_potential():
    """
    Factor over [cell_true_state, sensor_measurement]
    """
    def potential(cell_state: int, measurement: int) -> float:
        if cell_state >= 2:  # unknown true state
            return 1.0
        if measurement >= 3:
            return 1.0
        return SENSOR_MODEL[measurement, cell_state]
    
    return potential
```

