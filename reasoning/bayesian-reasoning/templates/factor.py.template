## Example: Heading Factor (Von Mises)

```python
# models/factors/heading_factor.py
import numpy as np
from scipy.special import i0

KAPPA = 50.0  # concentration (higher = more certain)

def get_potential():
    """
    Factor over [pose_theta, odom_theta]
    Von Mises distribution for circular variable
    """
    def potential(pose_theta: float, odom_theta: float) -> float:
        # Angle difference
        diff = pose_theta - odom_theta
        # Wrap to [-pi, pi]
        diff = np.arctan2(np.sin(diff), np.cos(diff))
        
        # Von Mises: exp(kappa * cos(diff)) / (2π * I0(kappa))
        return np.exp(KAPPA * np.cos(diff)) / (2 * np.pi * i0(KAPPA))
    
    return potential
```

