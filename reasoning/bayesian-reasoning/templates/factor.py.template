## Example: LiDAR Factor (Iterative Closest Point inspired)

```python
# models/factors/lidar_factor.py
import numpy as np

LIDAR_NOISE = 0.03  # meters
MAX_RANGE = 10.0

def get_potential():
    """
    Factor over [pose_x, pose_y, scan_id]
    scan_id indexes into a map of expected LiDAR readings for each pose cell
    """
    # Precomputed expected readings for each discretized pose cell
    # In practice, load from map file
    EXPECTED_READINGS = {
        0: {"x": 0.0, "y": 0.0, "range": 5.0},
        1: {"x": 1.0, "y": 0.0, "range": 4.0},
        # ... more cells
    }
    
    def potential(pose_x: float, pose_y: float, scan_id: int) -> float:
        if scan_id not in EXPECTED_READINGS:
            return 1.0  # uniform if unknown
        
        expected = EXPECTED_READINGS[scan_id]
        # Simplified: compare distance to expected landmark
        dx = pose_x - expected["x"]
        dy = pose_y - expected["y"]
        dist = np.sqrt(dx*dx + dy*dy)
        
        # Potential based on how well pose matches expected scan
        return np.exp(-0.5 * (dist - expected["range"])**2 / (LIDAR_NOISE**2))
    
    return potential
```

