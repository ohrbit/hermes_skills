## Example: Vision Factor (Gaussian + Outlier Model)

```python
# models/factors/vision_factor.py
import numpy as np

VISION_NOISE_XY = 0.02  # meters
OUTLIER_PROB = 0.05
OUTLIER_SCALE = 10.0

def get_potential():
    """
    Factor over [pose_x, pose_y, vision_x, vision_y]
    Mixture: (1-outlier_prob) * Gaussian + outlier_prob * Uniform
    """
    def potential(pose_x: float, pose_y: float, vision_x: float, vision_y: float) -> float:
        dx = vision_x - pose_x
        dy = vision_y - pose_y
        dist2 = dx*dx + dy*dy
        sigma2 = VISION_NOISE_XY**2
        
        # Inlier component
        inlier = np.exp(-0.5 * dist2 / sigma2) / (2 * np.pi * sigma2)
        
        # Outlier component (broad uniform)
        outlier = 1.0 / (OUTLIER_SCALE * OUTLIER_SCALE)
        
        return (1 - OUTLIER_PROB) * inlier + OUTLIER_PROB * outlier
    
    return potential
```

